{
  "schema_version": "1.0",
  "_note": "模板预设：theme(配色字阶) + layout(按 SlideType 的版式变体) + slot_map(字段映射/约束)。结构说明见 README.md。",
  "templates": [
    {
      "id": "baseline",
      "name": "万金油基准",
