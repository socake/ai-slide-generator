# 复制为 .env 后填值(.env 已被 gitignore)。
# 不填、且不加 --provider 时默认走 MockLLMProvider:离线、零成本、可复现(make demo / 测试)。
# 真实生成只在加 --provider 且配了对应 key 时才联网。

# ── OpenAI(也用于 OpenAI 兼容端点:把 BASE_URL 指向兼容服务即可)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ── DeepSeek 原生端点(--provider deepseek;便宜,默认 deepseek-chat)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Anthropic Claude(--provider anthropic)
ANTHROPIC_API_KEY=
